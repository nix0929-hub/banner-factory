# Banner Factory 백엔드 환경 변수 예시
# 이 파일을 복사해 .env로 저장한 뒤 실제 값을 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요.

# Anthropic API 키 (Claude 모델 사용)
ANTHROPIC_API_KEY=sk-ant-...

# Google Generative AI API 키 (Gemini Vision / Imagen 사용)
GOOGLE_API_KEY=AIza...

# 파일 업로드 최대 크기 (MB, 기본값: 10)
MAX_FILE_SIZE_MB=10

# 임시 파일 저장 디렉토리 (기본값: ./temp)
TEMP_DIR=./temp

# 임시 파일 보관 시간 (시간 단위, 기본값: 1)
TEMP_FILE_TTL_HOURS=1
